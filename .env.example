# Gender Equity Intelligence Platform - Environment Variables Example
# Copy this file to .env and fill in your actual values

# ==================== FRONTEND CONFIGURATION ====================

# API Base URL for backend communication
REACT_APP_API_URL=http://localhost:3001

# Firebase Configuration (Optional - if using Firestore)
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_firebase_project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_firebase_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
REACT_APP_FIREBASE_APP_ID=your_firebase_app_id
REACT_APP_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Feature Flags (Optional)
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_CHAT=true
REACT_APP_ENABLE_OFFLINE_MODE=false

# ==================== BACKEND CONFIGURATION ====================

# Server Port
PORT=3001

# Node Environment
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Google Gemini API Configuration (For Sakhi AI)
GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Database Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_DATABASE_URL=https://your_firebase_project.firebaseio.com

# Logging
LOG_LEVEL=info

# Rate Limiting (Optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Service (Optional - for future features)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# SMS Service (Optional - for future notifications)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Data Export Service (Optional)
EXPORT_MAX_RECORDS=100000
EXPORT_TIMEOUT_MS=30000

# ==================== MONITORING & ANALYTICS ====================

# Sentry Error Tracking (Optional)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
SENTRY_ENVIRONMENT=development

# Google Analytics (Optional)
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ==================== SECURITY ====================

# JWT Secret (Optional - if implementing token auth)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Session Secret (Optional)
SESSION_SECRET=your_session_secret_key

# HTTPS/SSL (Production)
HTTPS_ENABLED=false
SSL_KEY_PATH=
SSL_CERT_PATH=

# ==================== DEVELOPMENT TOOLS ====================

# Debug Mode
DEBUG=geip:*

# API Documentation
ENABLE_SWAGGER=true

# Database Query Logging
LOG_DB_QUERIES=false

# ==================== NOTES ====================
# 
# Security Best Practices:
# 1. Never commit the actual .env file - only commit .env.example
# 2. Add .env to .gitignore
# 3. Use strong, unique API keys in production
# 4. Rotate credentials regularly
# 5. Use environment-specific secrets
# 6. Don't hardcode sensitive data in source code
#
# Local Development Setup:
# - Copy this file: cp .env.example .env
# - Fill in your API keys and credentials
# - Restart the development server
#
# Production Deployment:
# - Use your hosting platform's environment variable settings
# - Never expose .env files in version control
# - Use secure secret management tools (AWS Secrets Manager, Heroku Config Vars, etc.)
#
